{
  "expo": {
    "name": "MindOrbit",
    "slug": "mindorbit-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mindorbit-logo.png",
    "scheme": "mindorbitmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "MindOrbit uses the microphone to record your voice check-in for mood analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F2ED",
        "foregroundImage": "./assets/images/mindorbit-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mindorbit-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mindorbit-logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#F5F2ED",
          "dark": {
            "backgroundColor": "#1a1f1c"
          }
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "MindOrbit uses the microphone to record your voice check-in for mood analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
